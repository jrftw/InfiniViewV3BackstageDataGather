NODE_ENV=production
TZ=America/New_York

APP_PORT=3099

# Backstage — US locale / timezone (matches LIVE Backstage USA experience)
BACKSTAGE_LOCALE=en-US
BACKSTAGE_TIMEZONE=America/New_York
BACKSTAGE_REGION=US
BACKSTAGE_ACCEPT_LANGUAGE=en-US,en;q=0.9
# Approximate geolocation for US English Backstage (New York — change if needed)
BACKSTAGE_GEO_LAT=40.7128
BACKSTAGE_GEO_LNG=-74.006

# Backstage login (.env only — NEVER commit). TIKTOK_* aliases also supported.
BACKSTAGE_EMAIL=
BACKSTAGE_PASSWORD=
# TIKTOK_EMAIL=
# TIKTOK_PASSWORD=
# HEADLESS=false  (same as BACKSTAGE_HEADLESS=false — show browser)

# Agency region in Backstage header — always switch to US+ if wrong (auto)
BACKSTAGE_AGENCY_REGION=US+
BACKSTAGE_FORCE_US_PLUS=true

# Backstage — set your agency Backstage URL after first visit
BACKSTAGE_BASE_URL=https://live-backstage.tiktok.com
BACKSTAGE_AUTH_STATE_PATH=data/auth/backstage-auth.json
# Creator Data (/portal/data/data) date window for Diamonds / LIVE stats
# month = current calendar month (Total Diamonds for this month)
# rolling = last N days (BACKSTAGE_PERFORMANCE_DAYS)
BACKSTAGE_PERFORMANCE_DATE_RANGE=month
BACKSTAGE_PERFORMANCE_DAYS=30
# Performance export column reset (Unselect all x2 → Select all) — retry/fallback only by default
GATHERER_PERFORMANCE_COLUMN_RESET=true
# Skip Customize data on first attempt (matches manual Backstage Creator Data export)
# GATHERER_PERFORMANCE_CUSTOMIZE_COLUMNS=false
# Map hybrid Creator Data exports where period metrics are labeled "in L30D"
GATHERER_CREATOR_DATA_L30D_PERIOD_FALLBACK=true
# Export previous calendar month on day 1 only when explicitly enabled
# GATHERER_EARLY_MONTH_FALLBACK=false
# false = show browser window (required for debugging / watching automation)
BACKSTAGE_HEADLESS=false
# Optional: slow clicks so you can follow along (milliseconds, 0 = off)
BACKSTAGE_SLOW_MO_MS=75

# Re-run login after changing locale/region so the saved session matches US settings:
#   npm run login

# Google Service Account (share Drive folder + Sheet with this email)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# Optional: Workspace domain-wide delegation — uploads use this user's Drive quota (My Drive folders)
# Admin Console → Domain-wide delegation → Client ID + scopes (drive + spreadsheets)
GOOGLE_DELEGATED_USER=
GOOGLE_SCOPES=https://www.googleapis.com/auth/drive,https://www.googleapis.com/auth/spreadsheets
GOOGLE_DRIVE_FOLDER_ID=
# Profile avatars subfolder inside Data Hub (default: Profile Pictures)
GOOGLE_DRIVE_PROFILE_IMAGES_SUBFOLDER=Profile Pictures
# Optional dedicated profile folder ID — leave blank when using Data Hub subfolder
# GOOGLE_DRIVE_PROFILE_IMAGES_FOLDER_ID=
# Daily history archive folder
GOOGLE_DRIVE_DAILY_ARCHIVE_FOLDER_ID=
GOOGLE_MASTER_SHEET_ID=

# External CRM sheet — email, phone, contact fields (reads leftmost tab unless GOOGLE_CRM_SHEET_TAB is set)
GOOGLE_CRM_SHEET_ID=1FpWOcsfMtlkbPPEDsrWvAuWCpVz6Yvh9OnPDkskVSUE
# GOOGLE_CRM_SHEET_TAB=

# External Diamond Incentive (DIP) sheet — tier/bonus fields (match on userId + cid)
GOOGLE_DIP_SHEET_ID=1LfSCDoCQB1bXUN9N6FRpvxuZck1Dffv8KZ1sfAFhIMk
GOOGLE_DIP_SHEET_GID=1551181949
# GOOGLE_DIP_SHEET_TAB=June 2026

LOCAL_DOWNLOAD_DIR=data/downloads
LOCAL_RAW_DIR=data/raw
LOCAL_PROCESSED_DIR=data/processed
LOCAL_LOG_DIR=data/logs
LOCAL_CACHE_DIR=cache/creators

RUN_SCHEDULE_1=08:00
RUN_SCHEDULE_2=12:00
RUN_SCHEDULE_3=16:00
RUN_SCHEDULE_4=20:00
# 24/7 hourly (fixed) — business day cutoff 8:00 PM America/New_York (= midnight UTC during EDT)
# RUN_SCHEDULES=00:00,01:00,02:00,03:00,04:00,05:00,06:00,07:00,08:00,09:00,10:00,11:00,12:00,13:00,14:00,15:00,16:00,17:00,18:00,19:00,20:00,21:00,22:00,23:00

# Scheduling mode: fixed (RUN_SCHEDULES or RUN_SCHEDULE_1..N) or random (jittered times below)
GATHERER_SCHEDULE_MODE=fixed
GATHERER_RUNS_PER_DAY=24
GATHERER_ACTIVE_HOURS_START=00:00
GATHERER_ACTIVE_HOURS_END=23:59
GATHERER_RUN_JITTER_MINUTES=0
GATHERER_MIN_MINUTES_BETWEEN_RUNS=50
# Daily cutoff + archive time (America/New_York — EST/EDT auto). 8:00 PM Eastern = midnight UTC during EDT.
GATHERER_DAILY_ARCHIVE_TIME=20:00
# After server restart, run once if no successful gather yet today (set false to disable)
GATHERER_CATCHUP_ON_STARTUP=true

# Storage — combined output is one file per day; raw exports are trimmed
KEEP_LOCAL_FILES_DAYS=14
GATHERER_KEEP_RAW_PAIRS_PER_DAY=4

# Clear saved Backstage cookies after N hours so the next run logs in again (0 = never)
GATHERER_BACKSTAGE_FORCE_RELOGIN_HOURS=8

# Optional: Daily_YYYY-MM-DD tab on master sheet (default false — use Drive archive folder instead)
GATHERER_DAILY_SHEET_TAB_PREFIX=Daily
GATHERER_UPDATE_MASTER_DAILY_TAB=false
# Master sheet: patch only changed creator rows by checksum (default true — no full-tab clear)
GATHERER_MASTER_SHEET_INCREMENTAL_UPDATES=true

# Human-friendly emoji console logs (true = on, false = raw JSON only)
GATHERER_FRIENDLY_LOGS=true
# Log every gatherer step to console + structured logs (set false for high-level only)
GATHERER_VERBOSE_STEPS=true
# Notification export poll interval in ms while waiting for Backstage to generate file (default 8000)
# GATHERER_NOTIFICATION_POLL_INTERVAL_MS=8000
# Friendly console: log poll status every N attempts (default 5; attempt 1 always logs)
# GATHERER_NOTIFICATION_POLL_LOG_EVERY=5
# Skip preflight checks on scheduled runs (optional speed boost)
# GATHERER_SKIP_PREFLIGHT=true

# Active roster filter — only creators on Manage creators appear in combined output (default: true)
GATHERER_REQUIRE_MANAGEMENT_MATCH=true
# Require relationship_status = Effective when present (default: true)
GATHERER_REQUIRE_EFFECTIVE_RELATIONSHIP=true
# Graduation statuses to exclude (comma-separated, case-insensitive substring match)
GATHERER_EXCLUDE_GRADUATION_STATUSES=quit,removed,expired

# Phase 2 — TikTok Public Profile Acquirer
GATHERER_PROFILE_ACQUIRER_ENABLED=true
# Chain profile acquirer immediately after each successful Backstage gather (scheduled + manual)
GATHERER_PROFILE_ACQUIRER_AFTER_BACKSTAGE=true
# true = only creators never profile-checked; false = also refresh stale creators (see STALE_HOURS)
GATHERER_PROFILE_ACQUIRER_AFTER_BACKSTAGE_NEW_ONLY=false
# Batch runs skip creators checked within this many hours (unless --force)
GATHERER_PROFILE_ACQUIRER_STALE_HOURS=24
# Max creators per batch profile acquirer run (rate-limit safety)
GATHERER_PROFILE_ACQUIRER_BATCH_LIMIT=25
# Use Playwright to load recent videos when TikTok SSR HTML has no itemList (default: true)
GATHERER_PROFILE_ACQUIRER_BROWSER_VIDEOS=true
# Headless Chromium for TikTok profile video scrape (default: true)
GATHERER_PROFILE_ACQUIRER_TIKTOK_HEADLESS=true

# Auto-update (server PC) — git branch to watch
GIT_UPDATE_BRANCH=main
GIT_UPDATE_CHECK_MINUTES=15

# MongoDB — production database dual-write (same cluster as InfiniCore API)
# When MONGODB_URI is set, each gather run upserts creators + one daily performance snapshot per creator.
MONGODB_URI=
MONGODB_DB_NAME=InfiniViewV3
# Set false to disable MongoDB publish while keeping URI in .env for other tools
GATHERER_MONGODB_ENABLED=true
# Keep one performance snapshot per creator per calendar day (newest run wins). Set false for legacy append-only mode.
GATHERER_MONGO_SNAPSHOT_ONE_PER_DAY=true

# Priority 1 — Daily Snapshot History Engine (Drive archive → creator_daily_snapshots)
# Imports InfiniView Creators YYYY-MM-DD / Combined Creators into MongoDB nightly at 12:30 AM ET
GATHERER_SNAPSHOT_HISTORY_IMPORT_ENABLED=true
GATHERER_SNAPSHOT_HISTORY_IMPORT_TIME=00:30
GATHERER_SNAPSHOT_HISTORY_COMBINED_TAB=Combined Creators
# CLI: npm run snapshot-history:backfill  |  npm run snapshot-history:verify -- --month=2026-07

# Priority 9 — Auto Highlights scan (InfiniView API /internal/community/highlights/scan)
# Opt-in: set GATHERER_AUTO_HIGHLIGHTS_SCAN_ENABLED=true when ready to ship Gatherer-side scans.
# When enabled: hourly from 8 AM–8 PM America/New_York (max 13 scans/day; API caps posts at 10/day).
GATHERER_AUTO_HIGHLIGHTS_SCAN_ENABLED=false
GATHERER_AUTO_HIGHLIGHTS_SCAN_ACTIVE_HOUR_START=8
GATHERER_AUTO_HIGHLIGHTS_SCAN_ACTIVE_HOUR_END=20
INFINIVIEW_API_BASE_URL=https://us-central1-infiniviewv3.cloudfunctions.net/api
# INFINIVIEW_INTERNAL_SERVICE_SECRET=
# INFINIVIEW_HIGHLIGHT_SCAN_TIMEOUT_MS=15000

# Optional DNS servers for mongodb+srv:// SRV lookup on Windows server PC
# GATHERER_MONGODB_DNS_SERVERS=8.8.8.8,8.8.4.4,1.1.1.1

# Optional InfinitumServerAgent — post-publish snapshot import / mongo summary sync (additive; gatherer succeeds if agent is down)
INFINITUM_AGENT_ENABLED=false
INFINITUM_AGENT_BASE_URL=http://10.0.0.65:9090
INFINITUM_AGENT_API_TOKEN=
INFINITUM_AGENT_TIMEOUT_MS=5000

# Failure email alerts — sent when gatherer run fails (Gmail API via service account)
# Requires GOOGLE_DELEGATED_USER + gmail.send on domain-wide delegation in Google Admin
GATHERER_FAILURE_EMAIL_ENABLED=true
GATHERER_FAILURE_EMAIL_TO=kdoyle@infinitumimagery.com
# Optional — defaults to GOOGLE_DELEGATED_USER
# GATHERER_FAILURE_EMAIL_FROM=kdoyle@infinitumimagery.com
