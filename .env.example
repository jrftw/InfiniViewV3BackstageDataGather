NODE_ENV=production
TZ=America/New_York

APP_PORT=3099

# Backstage — US locale / timezone (matches LIVE Backstage USA experience)
BACKSTAGE_LOCALE=en-US
BACKSTAGE_TIMEZONE=America/New_York
BACKSTAGE_REGION=US
BACKSTAGE_ACCEPT_LANGUAGE=en-US,en;q=0.9
# Approximate geolocation for US English Backstage (New York — change if needed)
BACKSTAGE_GEO_LAT=40.7128
BACKSTAGE_GEO_LNG=-74.006

# Backstage login (.env only — NEVER commit). TIKTOK_* aliases also supported.
BACKSTAGE_EMAIL=
BACKSTAGE_PASSWORD=
# TIKTOK_EMAIL=
# TIKTOK_PASSWORD=
# HEADLESS=false  (same as BACKSTAGE_HEADLESS=false — show browser)

# Agency region in Backstage header — always switch to US+ if wrong (auto)
BACKSTAGE_AGENCY_REGION=US+
BACKSTAGE_FORCE_US_PLUS=true

# Backstage — set your agency Backstage URL after first visit
BACKSTAGE_BASE_URL=https://live-backstage.tiktok.com
BACKSTAGE_AUTH_STATE_PATH=data/auth/backstage-auth.json
# Creator Data (/portal/data/data) date window for Diamonds / LIVE stats
# month = current calendar month (Total Diamonds for this month)
# rolling = last N days (BACKSTAGE_PERFORMANCE_DAYS)
BACKSTAGE_PERFORMANCE_DATE_RANGE=month
BACKSTAGE_PERFORMANCE_DAYS=30
# false = show browser window (required for debugging / watching automation)
BACKSTAGE_HEADLESS=false
# Optional: slow clicks so you can follow along (milliseconds, 0 = off)
BACKSTAGE_SLOW_MO_MS=75

# Re-run login after changing locale/region so the saved session matches US settings:
#   npm run login

# Google Service Account (share Drive folder + Sheet with this email)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_DRIVE_FOLDER_ID=
# Daily history archive — separate Google Sheet per day on scheduled run 4 (final run of day)
GOOGLE_DRIVE_DAILY_ARCHIVE_FOLDER_ID=1YyL3Djct37J1ZVug5f0PclAz9PGHD473
GOOGLE_MASTER_SHEET_ID=

# External CRM sheet — email, phone, contact fields (reads leftmost tab unless GOOGLE_CRM_SHEET_TAB is set)
GOOGLE_CRM_SHEET_ID=1FpWOcsfMtlkbPPEDsrWvAuWCpVz6Yvh9OnPDkskVSUE
# GOOGLE_CRM_SHEET_TAB=

# External Diamond Incentive (DIP) sheet — tier/bonus fields (match on userId + cid)
GOOGLE_DIP_SHEET_ID=1LfSCDoCQB1bXUN9N6FRpvxuZck1Dffv8KZ1sfAFhIMk
GOOGLE_DIP_SHEET_GID=1551181949
# GOOGLE_DIP_SHEET_TAB=June 2026

LOCAL_DOWNLOAD_DIR=data/downloads
LOCAL_RAW_DIR=data/raw
LOCAL_PROCESSED_DIR=data/processed
LOCAL_LOG_DIR=data/logs
LOCAL_CACHE_DIR=cache/creators

RUN_SCHEDULE_1=08:00
RUN_SCHEDULE_2=12:00
RUN_SCHEDULE_3=16:00
RUN_SCHEDULE_4=20:00
# Or comma list: RUN_SCHEDULES=07:30,10:15,13:00,16:45,20:00

# Scheduling mode: fixed (above times) or random (jittered times below)
GATHERER_SCHEDULE_MODE=random
GATHERER_RUNS_PER_DAY=10
GATHERER_ACTIVE_HOURS_START=07:30
GATHERER_ACTIVE_HOURS_END=22:30
GATHERER_RUN_JITTER_MINUTES=18
GATHERER_MIN_MINUTES_BETWEEN_RUNS=55
# Daily cutoff + archive time (America/New_York — EST/EDT auto). 8:00 PM Eastern = midnight UTC during EDT.
GATHERER_DAILY_ARCHIVE_TIME=20:00

# Storage — combined output is one file per day; raw exports are trimmed
KEEP_LOCAL_FILES_DAYS=14
GATHERER_KEEP_RAW_PAIRS_PER_DAY=4

# Clear saved Backstage cookies after N hours so the next run logs in again (0 = never)
GATHERER_BACKSTAGE_FORCE_RELOGIN_HOURS=8

# Optional: Daily_YYYY-MM-DD tab on master sheet (default false — use Drive archive folder instead)
GATHERER_DAILY_SHEET_TAB_PREFIX=Daily
GATHERER_UPDATE_MASTER_DAILY_TAB=false

# Human-friendly emoji console logs (true = on, false = raw JSON only)
GATHERER_FRIENDLY_LOGS=true
# Skip preflight checks on scheduled runs (optional speed boost)
# GATHERER_SKIP_PREFLIGHT=true

# Active roster filter — only creators on Manage creators appear in combined output (default: true)
GATHERER_REQUIRE_MANAGEMENT_MATCH=true
# Require relationship_status = Effective when present (default: true)
GATHERER_REQUIRE_EFFECTIVE_RELATIONSHIP=true
# Graduation statuses to exclude (comma-separated, case-insensitive substring match)
GATHERER_EXCLUDE_GRADUATION_STATUSES=quit,removed,expired

# Auto-update (server PC) — git branch to watch
GIT_UPDATE_BRANCH=main
GIT_UPDATE_CHECK_MINUTES=15
